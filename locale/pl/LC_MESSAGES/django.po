msgstr ""
"Dostarczenie wiadomości e-mail nie powiodło się. Sprawdź dzienniki aplikacji "
"pod kątem szczegółów technicznych."

#: .\clients\views\emails.py:237
msgid "Не найдено получателей по заданным фильтрам (с указанным email)."
msgstr "Nie znaleziono odbiorców odpowiadających filtrom (z adresem e-mail)."

#: .\clients\views\emails.py:251
#, python-format
