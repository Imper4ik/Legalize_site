msgstr "Nieprawidłowy cel składania wniosku."

#: .\clients\views\onboarding_step_return.py:342
msgid "Invalid date format for legal stay. Expected YYYY-MM-DD."
msgstr ""
"Nieprawidłowy format daty legalnego pobytu. Oczekiwany format: RRRR-MM-DD."

#: .\clients\views\onboarding_views.py:79
#: .\clients\views\onboarding_views.py:926
