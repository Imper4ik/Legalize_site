#: .\clients\views\onboarding_step_return.py:158
msgid "Скан паспорта успешно загружен. Данные распознаются."
msgstr "Skan paszportu został pomyślnie przesłany. Dane są rozpoznawane."

#: .\clients\views\onboarding_step_return.py:161
#: .\clients\views\onboarding_views.py:621
