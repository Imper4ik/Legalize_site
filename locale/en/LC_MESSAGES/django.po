#: clients/templates/clients/privacy_policy.html:15
msgid "1. Администратор данных"
msgstr "1. Data controller"

#: clients/templates/clients/privacy_policy.html:19
msgid "Реквизиты администратора данных уточняются в офисе."
msgstr "The data controller's details are available from the office."

