DJANGO_SETTINGS_MODULE=legalize_site.settings.production
APP_ENV=production

SECRET_KEY=replace-me
FERNET_KEYS=replace-with-comma-separated-fernet-keys

ALLOWED_HOSTS=crm.example.com
CSRF_TRUSTED_ORIGINS=https://crm.example.com
# Railway may provide these automatically. Keep ALLOWED_HOSTS/CSRF_TRUSTED_ORIGINS
# explicit, or set RAILWAY_PUBLIC_DOMAIN/RAILWAY_STATIC_URL for derived values.
RAILWAY_PUBLIC_DOMAIN=
RAILWAY_STATIC_URL=
RENDER_EXTERNAL_HOSTNAME=
# Optional. If unset in production, rate limiting uses the PostgreSQL cache table.
REDIS_URL=
DJANGO_CACHE_TABLE=cache_table

SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# Content-Security-Policy. The enforced policy currently allows 'unsafe-inline'.
# Set LEGALIZE_CSP_STRICT_REPORT_ONLY=True to ALSO emit a stricter policy in
# Report-Only mode (no 'unsafe-inline'); the browser reports violations without
# breaking anything, so you can inventory inline scripts/handlers before
# enforcing the strict policy. Safe to leave False.
LEGALIZE_CSP_REPORT_ONLY=False
LEGALIZE_CSP_STRICT_REPORT_ONLY=False

DEFAULT_FROM_EMAIL=noreply@example.com
REPLY_TO_EMAIL=support@example.com

# Railway MVP default: store uploaded client documents in the database.
# For larger production deployments, switch to S3/R2/B2 below.
USE_DATABASE_MEDIA_STORAGE=True
DATABASE_MEDIA_FALLBACK_TO_FILE_SYSTEM=true
DATABASE_MEDIA_AUTO_IMPORT_LEGACY_FILES=true
DATABASE_MEDIA_TEMP_ROOT=/app/tmp/database_media

BACKUP_REMOTE_STORAGE=false
BACKUP_STORAGE_ALIAS=backups
BACKUP_STORAGE_LOCATION=db_backups
MAX_BACKUP_AGE_HOURS=24

ASYNC_OCR_PROCESSING=false
# Set ASYNC_OCR_PROCESSING=true only when a worker/cron runs process_document_jobs.

# S3/R2/B2 media storage option. Enable only when USE_DATABASE_MEDIA_STORAGE=False.
USE_S3_MEDIA_STORAGE=False
AWS_STORAGE_BUCKET_NAME=private-media
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_S3_REGION_NAME=eu-central-1
AWS_S3_ENDPOINT_URL=https://s3.example.com
AWS_S3_CUSTOM_DOMAIN=
PRIVATE_MEDIA_LOCATION=private

# Alternative to S3/DB storage: mount a Railway Volume to this exact path and acknowledge it.
# Without S3, DB storage, or an explicitly acknowledged persistent volume, production checks fail.
MEDIA_ROOT=/app/media
ALLOW_PRODUCTION_LOCAL_MEDIA=false


RATE_LIMIT_LOGIN=5
RATE_LIMIT_LOGIN_WINDOW=300
RATE_LIMIT_DOCUMENT_UPLOAD=80
RATE_LIMIT_DOCUMENT_UPLOAD_WINDOW=3600

LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Task and Backup settings
CRON_TOKEN=
BACKUP_TRIGGER_SECRET=
CRON_ALLOWED_IPS=

# Admin User Bootstrapping
DJANGO_BOOTSTRAP_SUPERUSER=auto
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_RESET_SUPERUSER_PASSWORD=0

# Export & Cleanup limits
MAX_TOTAL_CLIENT_EXPORT_MB=200
DATABASE_MEDIA_TEMP_MAX_AGE_HOURS=24

# Translation Studio. Keep disabled in production unless the internal editor is
# intentionally exposed to authenticated translator/admin roles.
ENABLE_TRANSLATION_TOOLING=False
TRANSLATION_STUDIO_STORAGE=database
TRANSLATION_DB_OVERRIDES_ENABLED=True

# Gunicorn (start.sh)
WEB_CONCURRENCY=3
WEB_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_MAX_REQUESTS=1200
GUNICORN_MAX_REQUESTS_JITTER=200

# Test Center and Demo Center
ENABLE_TEST_CENTER=False
DEMO_MODE_ENABLED=False
TEST_CENTER_MEDIA_ROOT=
DEMO_CENTER_MEDIA_ROOT=
